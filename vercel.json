{
  "buildCommand": "cd hotel-booking-frontend && npm install && npm run build",
  "outputDirectory": "dist",
  "installCommand": "cd hotel-booking-frontend && npm install",
  "env": {
    "VITE_API_BASE_URL": "https://glangetaway-2-1.onrender.com"
  },
  "rewrites": [
    {
      "source": "/admin-login",
      "destination": "/index.html"
    },
    {
      "source": "/admin-dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/admin-dashboard/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}