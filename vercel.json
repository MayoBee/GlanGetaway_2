{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "build": {
    "env": {
      "VITE_API_BASE_URL": "https://glangetaway-2-1.onrender.com"
    }
  },
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/admin-login",
      "destination": "/index.html"
    },
    {
      "source": "/admin-dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/admin-dashboard/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "ignore": [
    "ResortManagementBooking/**",
    "node_modules/**",
    ".git/**"
  ]
}