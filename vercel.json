{
  "version": 2,
  "name": "glangetaway-booking",
  "builds": [
    {
      "src": "ResortManagementBooking/hotel-booking-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/ResortManagementBooking/hotel-booking-frontend/$1"
    }
  ],
  "installCommand": "cd ResortManagementBooking/hotel-booking-frontend && npm install",
  "buildCommand": "cd ResortManagementBooking/hotel-booking-frontend && npm run build",
  "outputDirectory": "ResortManagementBooking/hotel-booking-frontend/dist",
  "framework": "vite"
}
