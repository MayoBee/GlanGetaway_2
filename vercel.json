{
  "buildCommand": "npm install --prefix hotel-booking-frontend && npm run build --prefix hotel-booking-frontend",
  "outputDirectory": "hotel-booking-frontend/dist",
  "installCommand": "npm install --prefix hotel-booking-frontend",
  "rewrites": [
    {
      "source": "/admin-login",
      "destination": "/index.html"
    },
    {
      "source": "/admin-dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/admin-dashboard/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}