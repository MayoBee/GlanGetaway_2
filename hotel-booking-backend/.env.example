# Database Configuration
MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/hotel-booking

# JWT Configuration
JWT_SECRET_KEY=your-super-secure-production-jwt-secret-key-minimum-32-characters

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Stripe Configuration (for payments)
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key

# Environment
NODE_ENV=production
PORT=5000

# Frontend URL (for CORS) - Update with your Vercel frontend URL
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Backend URL - Update with your Render backend URL
BACKEND_URL=https://your-backend-app.onrender.com

# Admin Access Control
# Admin users are automatically blocked from logging in through the main website
# They must use the admin portal at /admin

# Additional Production Variables
CORS_ORIGIN=https://your-frontend-domain.vercel.app
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
